#!/usr/bin/env python3
"""Fuel Upload Language Experiment — per-language tests, Quarto book serving, deploy."""

import os
import subprocess
import sys

ROOT = os.path.dirname(os.path.abspath(__file__))

# ── Helpers ──────────────────────────────────────────────────────────────

def run(cmd, **kw):
    return subprocess.run(cmd, shell=True, cwd=ROOT, **kw)

def run_capture(cmd):
    r = subprocess.run(cmd, shell=True, cwd=ROOT, capture_output=True, text=True)
    return r.stdout.strip()

def bold(s):   return f"\033[1m{s}\033[0m"
def green(s):  return f"\033[32m{s}\033[0m"
def red(s):    return f"\033[31m{s}\033[0m"
def yellow(s): return f"\033[33m{s}\033[0m"
def cyan(s):   return f"\033[36m{s}\033[0m"
def dim(s):    return f"\033[2m{s}\033[0m"

def heading(s):
    print(f"\n{bold(cyan(s))}")
    print(cyan("─" * 40))

def step(cmd):
    print(dim(f"$ {cmd}"))
    return run(cmd).returncode

def must(cmd):
    rc = step(cmd)
    if rc != 0:
        print(red(f"✗ failed: {cmd}"))
        sys.exit(rc)

# ── Per-language tests ───────────────────────────────────────────────────

def cmd_test_cs():
    heading("C# tests")
    must("dotnet test csharp-fuel-engine/FuelUploadEngine.slnx")

def cmd_test_fs():
    heading("F# tests")
    must("dotnet test fsharp-fuel-engine/FSharpFuelEngine.slnx")

def cmd_test_hs():
    heading("Haskell tests")
    must("cd haskell-fuel-engine && cabal test all")

def cmd_test_rs():
    heading("Rust check (fmt + test + clippy)")
    must("cd rust-fuel-engine && cargo fmt --check")
    must("cd rust-fuel-engine && cargo test")
    must("cd rust-fuel-engine && cargo clippy --all-targets -- -D warnings")

def cmd_test_all():
    cmd_test_cs()
    cmd_test_fs()
    cmd_test_hs()
    cmd_test_rs()
    print(green("\n✓ all language test suites passed"))

# ── Format ───────────────────────────────────────────────────────────────

def cmd_format():
    heading("Format check (all languages)")
    must("dotnet format csharp-fuel-engine/FuelUploadEngine.slnx --verify-no-changes --verbosity minimal")
    must("dotnet format fsharp-fuel-engine/FSharpFuelEngine.slnx --verify-no-changes --verbosity minimal")
    must("cd rust-fuel-engine && cargo fmt --check")
    print(green("✓ formatting clean"))

def cmd_format_fix():
    heading("Apply formatters")
    step("dotnet format csharp-fuel-engine/FuelUploadEngine.slnx")
    step("dotnet format fsharp-fuel-engine/FSharpFuelEngine.slnx")
    step("cd rust-fuel-engine && cargo fmt")

# ── Quarto book ──────────────────────────────────────────────────────────

def cmd_book_serve():
    heading("Serve Quarto book via Jupyter")
    run("tools/serve_quarto_book_jupyter.sh")

def cmd_book_static():
    heading("Render static book")
    must("python3 tools/render_static_book.py")
    print(green("✓ static book rendered to docs/book/"))

def cmd_book_render():
    heading("Quarto render → HTML")
    must("cd book && quarto render --to html")

def cmd_book_docker_up():
    heading("Start book Docker services")
    must("docker compose -f docker-compose.book.yml up -d --build")
    step("docker compose -f docker-compose.book.yml ps")

def cmd_book_docker_down():
    heading("Stop book Docker services")
    step("docker compose -f docker-compose.book.yml down")

def cmd_book_docker_logs():
    run("docker compose -f docker-compose.book.yml logs -f --tail=200")

def cmd_book_deploy():
    heading("Deploy Jupyter container and static book")
    must("bash scripts/deploy_book_server.sh")

# ── Docs / experiment ────────────────────────────────────────────────────

def cmd_results():
    heading("V2 scores")
    run("cat docs/v2-results.md | head -80")

def cmd_phases():
    heading("Phase-by-phase agent notes")
    step("ls docs/agent-notes/")

# ── MCP — delegate to tk-mcp ─────────────────────────────────────────────

def cmd_mcp():        run("tk-mcp list")
def cmd_mcp_add():    run("tk-mcp add")
def cmd_mcp_remove(): run("tk-mcp remove")

# ── Commands & menu ──────────────────────────────────────────────────────

COMMANDS = {
    "test":        ("Run all language test suites",       cmd_test_all),
    "test:cs":     ("C# tests (dotnet test)",             cmd_test_cs),
    "test:fs":     ("F# tests (dotnet test)",             cmd_test_fs),
    "test:hs":     ("Haskell tests (cabal test all)",     cmd_test_hs),
    "test:rs":     ("Rust fmt + test + clippy",           cmd_test_rs),

    "format":      ("Format check (all languages)",       cmd_format),
    "format:fix":  ("Apply formatters in place",          cmd_format_fix),

    "book":        ("Serve Quarto book via Jupyter",      cmd_book_serve),
    "book:static": ("Render static HTML book",            cmd_book_static),
    "book:render": ("Quarto render → HTML",               cmd_book_render),
    "book:up":     ("Docker compose up book services",    cmd_book_docker_up),
    "book:down":   ("Docker compose down book services",  cmd_book_docker_down),
    "book:logs":   ("Tail book Docker logs",              cmd_book_docker_logs),
    "book:deploy": ("Deploy Jupyter + static book",       cmd_book_deploy),
    "deploy":      ("Deploy Jupyter + static book",       cmd_book_deploy),

    "results":     ("Show V2 results doc head",           cmd_results),
    "phases":      ("List per-phase agent notes",         cmd_phases),

    "mcp":         ("List project MCP servers",           cmd_mcp),
    "mcp:add":     ("Enable an MCP server",               cmd_mcp_add),
    "mcp:remove":  ("Disable an MCP server",              cmd_mcp_remove),
}

SECTIONS = [
    ("Tests",  ["test", "test:cs", "test:fs", "test:hs", "test:rs"]),
    ("Format", ["format", "format:fix"]),
    ("Book",   ["book", "book:static", "book:render", "book:up", "book:down", "book:logs", "book:deploy", "deploy"]),
    ("Docs",   ["results", "phases"]),
    ("MCP",    ["mcp", "mcp:add", "mcp:remove"]),
]

def show_menu():
    print(f"\n{bold('Fuel Upload Experiment')} {dim('okgo')}")
    print()
    idx = 1
    num_map = {}
    for section, keys in SECTIONS:
        print(f"  {bold(section)}")
        for key in keys:
            desc, _ = COMMANDS[key]
            print(f"    {dim(str(idx) + '.')} {key:<14} {dim(desc)}")
            num_map[idx] = key
            idx += 1
        print()
    return num_map

def interactive():
    while True:
        num_map = show_menu()
        try:
            choice = input(f"{cyan('>')} ").strip()
        except (KeyboardInterrupt, EOFError):
            print()
            break
        if choice.lower() in ("q", "quit", "exit", ""):
            break
        if choice.isdigit() and int(choice) in num_map:
            key = num_map[int(choice)]
        elif choice in COMMANDS:
            key = choice
        else:
            print(red(f"Unknown: {choice}"))
            continue
        _, fn = COMMANDS[key]
        try:
            fn()
        except KeyboardInterrupt:
            print()
        except SystemExit:
            pass

def main():
    if len(sys.argv) > 1:
        cmd = sys.argv[1]
        if cmd in ("-h", "--help", "help"):
            print(f"Usage: {sys.argv[0]} [command]")
            print("\nCommands:")
            for key, (desc, _) in COMMANDS.items():
                print(f"  {key:<14} {desc}")
            return
        if cmd not in COMMANDS:
            print(red(f"Unknown command: {cmd}"))
            sys.exit(1)
        _, fn = COMMANDS[cmd]
        fn()
    else:
        interactive()

if __name__ == "__main__":
    main()
